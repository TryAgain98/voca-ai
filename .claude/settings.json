{
  "permissions": {
    "allow": [
      "Bash(npm run *)",
      "Bash(npm install *)",
      "Bash(npm view *)",
      "Bash(npm audit)",
      "Bash(npx tsc *)",
      "Bash(npx supabase *)",
      "Bash(npx shadcn@latest *)",
      "Bash(git status)",
      "Bash(git log *)",
      "Bash(git diff *)",
      "Bash(git add *)",
      "Bash(git commit *)",
      "Bash(find * -not -path '*/node_modules/*' -not -path '*/.git/*')",
      "Bash(grep -r * --include='*.ts' --include='*.tsx')"
    ],
    "deny": [
      "Bash(git push --force *)",
      "Bash(git reset --hard *)",
      "Bash(rm -rf *)"
    ]
  }
}
